{%- comment -%}
  Split shop tiles — SHOP MEN / SHOP WOMEN (add up to 3 tiles).
  Hover: image zoom + lime tint + CTA reveal. Mobile: stacked cards.
{%- endcomment -%}
<section class="shop-split" style="--split-count: {{ section.blocks.size | default: 2 }}">
  {%- for block in section.blocks -%}
    <a
      href="{% if block.settings.collection != blank %}{{ block.settings.collection.url }}{% else %}{{ block.settings.link }}{% endif %}"
      class="split-tile reveal{% if forloop.index == 2 %} reveal-d1{% elsif forloop.index == 3 %} reveal-d2{% endif %}"
      {{ block.shopify_attributes }}
    >
      <div class="split-tile__media" aria-hidden="true">
        {%- if block.settings.image -%}
          <img
            class="parallax-img"
            src="{{ block.settings.image | image_url: width: 1200 }}"
            srcset="{{ block.settings.image | image_url: width: 700 }} 700w,
                    {{ block.settings.image | image_url: width: 1200 }} 1200w"
            sizes="(min-width: 750px) 50vw, 100vw"
            alt="" width="1200" height="1500" loading="lazy"
          >
        {%- else -%}
          <div style="width:100%;height:100%;background:linear-gradient(160deg,#161d0b,#0a0a0a)"></div>
        {%- endif -%}
      </div>
      <div class="split-tile__overlay" aria-hidden="true"></div>
      <div class="split-tile__content">
        <div class="split-tile__label">{{ block.settings.label }}</div>
        <span class="split-tile__cta">{{ block.settings.cta | default: 'Shop now' }} {% render 'icon-arrow' %}</span>
      </div>
    </a>
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Shop Men / Women",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (3:4 or taller)" },
        { "type": "text", "id": "label", "label": "Label", "default": "Shop Men" },
        { "type": "text", "id": "cta", "label": "CTA text", "default": "Shop now" },
        { "type": "collection", "id": "collection", "label": "Collection (preferred)" },
        { "type": "url", "id": "link", "label": "OR custom link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop Men / Women",
      "blocks": [
        { "type": "tile", "settings": { "label": "Shop Men" } },
        { "type": "tile", "settings": { "label": "Shop Women" } }
      ]
    }
  ]
}
{% endschema %}
