<section class="section-pad" style="border-top:1px solid rgba(255,255,255,.06)">
  <div class="page-width">
    <div class="section-head">
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div
      class="product-grid"
      data-related-products
      data-product-id="{{ product.id }}"
      data-section-id="{{ section.id }}"
    >
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        {%- for rec in recommendations.products -%}
          {% render 'product-card', card_product: rec %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Related products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Complete the fit" }
  ]
}
{% endschema %}
