{%- if section.settings.show -%}
<div class="announcement-bar" role="region" aria-label="{{ 'general.announcement' | t }}">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
  {%- else -%}
    {{ section.settings.text }}
  {%- endif -%}
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping across the UAE over AED 250 · Members earn ATP points on every order"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    }
  ]
}
{% endschema %}
