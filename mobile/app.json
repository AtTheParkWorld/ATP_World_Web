{
  "expo": {
    "name": "At The Park",
    "slug": "atp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "atp",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/icon.png",
    "splash": {
      "backgroundColor": "#0a0a0a"
    },
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "world.atthepark.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "associatedDomains": [
        "applinks:www.atthepark.world",
        "applinks:atthepark.world"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "ATP uses the camera so ambassadors can scan member QR codes at the start of a session.",
        "NSPhotoLibraryUsageDescription": "ATP uses your photo library so you can attach an image to community posts.",
        "NSPhotoLibraryAddUsageDescription": "ATP saves your member QR badge to your photo library when you tap Save.",
        "NSHealthShareUsageDescription": "ATP reads your workouts from HealthKit to credit your fitness challenges. We never share or sell this data.",
        "NSHealthUpdateUsageDescription": "ATP does not write data to HealthKit — we only read your workouts to credit your fitness challenges.",
        "NSUserTrackingUsageDescription": "ATP does not currently use cross-site tracking. This will appear only if a future analytics provider requires it.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "world.atthepark.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-foreground.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.RECORD_AUDIO",
        "com.google.android.gms.permission.AD_ID"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.atthepark.world"
            },
            {
              "scheme": "https",
              "host": "atthepark.world"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "ATP uses the camera so ambassadors can scan member QR codes."
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "ATP does not currently use cross-site tracking. This prompt only appears if a future analytics provider requires it."
        }
      ],
      "expo-apple-authentication",
      "expo-font",
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "atthepark",
          "project": "atp-mobile"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b9991975-6cb8-4a0a-b8c5-e91d2a372bd6",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "world.atthepark.app.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.world.atthepark.app.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        }
      },
      "apiBaseUrl": "https://atp-world-web.onrender.com/api",
      "apiBaseUrlLegacyWebDomain": "https://www.atthepark.world/api",
      "appealUrl": "https://atthepark.world/appeal",
      "oneSignalAppId": "ff76a396-652d-436a-92fa-d94a6b9db280",
      "amplitudeApiKey": "",
      "sentryDsn": "https://56ea93c480fa8ea2b2c0acbbf7e8447e@o4511599230779392.ingest.de.sentry.io/4511599269773392",
      "stripePublishableKey": "",
      "googleIosClientId": "206407083569-is1kbav03g4gbd543deb0ivtkfv8pq2t.apps.googleusercontent.com",
      "googleAndroidClientId": "",
      "googleWebClientId": "206407083569-1dh2uj8kfvnbkbt2jtlp6kt50otn3ukb.apps.googleusercontent.com"
    },
    "owner": "at-the-park",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b9991975-6cb8-4a0a-b8c5-e91d2a372bd6"
    }
  }
}
