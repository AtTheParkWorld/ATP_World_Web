{
  "name": "atp-mobile",
  "version": "0.1.0",
  "description": "At The Park — Mobile App (React Native + Expo). Connects to the same backend as atthepark.world.",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "build:ios:dev": "eas build -p ios --profile development",
    "build:ios:prod": "eas build -p ios --profile production",
    "build:android:dev": "eas build -p android --profile development",
    "build:android:prod": "eas build -p android --profile production",
    "submit:ios": "eas submit -p ios --latest",
    "submit:android": "eas submit -p android --latest"
  },
  "dependencies": {
    "expo": "^51.0.0",
    "expo-dev-client": "~4.0.29",
    "expo-updates": "~0.25.27",
    "expo-router": "~3.5.14",
    "expo-linking": "~6.3.1",
    "expo-constants": "~16.0.2",
    "expo-status-bar": "~1.12.1",
    "expo-splash-screen": "~0.27.5",
    "expo-secure-store": "~13.0.2",
    "expo-application": "~5.9.1",
    "expo-camera": "~15.0.16",
    "expo-tracking-transparency": "~4.0.2",
    "expo-keep-awake": "~13.0.2",
    "expo-brightness": "~12.0.1",
    "expo-localization": "~15.0.3",
    "expo-image": "~1.12.15",
    "expo-font": "~12.0.10",
    "expo-apple-authentication": "~6.4.2",
    "expo-auth-session": "~5.5.2",
    "expo-web-browser": "~13.0.3",
    "expo-crypto": "~13.0.2",
    "expo-image-picker": "~15.0.7",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-screens": "3.31.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-svg": "15.2.0",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-mmkv": "^2.12.2",
    "react-native-onesignal": "5.2.6",
    "onesignal-expo-plugin": "2.0.3",
    "@stripe/stripe-react-native": "0.38.6",
    "@sentry/react-native": "~5.24.3",
    "@amplitude/analytics-react-native": "^1.4.10",
    "@tanstack/react-query": "^5.51.23",
    "@expo-google-fonts/dm-sans": "^0.2.3",
    "@expo-google-fonts/barlow-condensed": "^0.2.3",
    "zustand": "^4.5.4",
    "nativewind": "^4.0.36",
    "tailwindcss": "^3.4.10",
    "react-hook-form": "^7.52.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  }
}
