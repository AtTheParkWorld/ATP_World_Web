# ============================================================================
# ATP backend — environment variables
# ============================================================================
# Copy this file to .env (which is gitignored) and fill in real values.
# Production values live in Railway → service → Variables. Never commit
# real secrets. Anything here should be a placeholder.

# ── REQUIRED ────────────────────────────────────────────────────────────────

# Postgres connection string. Neon URL format:
#   postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Random secret used to sign JWTs. Generate with `openssl rand -hex 32`.
# Rotating this invalidates every existing token, so don't change it
# in production unless you intend to log everyone out.
JWT_SECRET=replace-with-openssl-rand-hex-32

# How long auth tokens stay valid (e.g. 7d, 24h, 90d).
JWT_EXPIRES_IN=7d

# Setup key for the /api/auth/migrate-* endpoints. Required for any
# schema migration. Rotate via Railway whenever you suspect a leak —
# after rotation the old key returns 401 immediately.
ADMIN_SETUP_KEY=replace-with-strong-random-string

# Server port. Railway injects this automatically in production.
PORT=3000

# Node environment — controls error-stack exposure + morgan log format.
NODE_ENV=development

# Where the SPA is served from. Used for CORS allowlist + Stripe
# success/cancel URLs.
FRONTEND_URL=http://localhost:3000


# ── EMAIL (SendGrid) ────────────────────────────────────────────────────────
# Used for magic-link auth emails + ambassador application notifications.
# Leave blank locally — the email service swallows errors when no key is set.
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@atthepark.world
EMAIL_FROM_NAME=At The Park


# ── GOOGLE OAUTH (optional) ─────────────────────────────────────────────────
# Only needed if you wire up Sign in with Google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── STRIPE (Theme 10 — premium subscriptions + paid sessions) ───────────────
# Get from Stripe Dashboard → Developers → API keys.
# Use sk_test_… in dev and sk_live_… in production.
STRIPE_SECRET_KEY=

# Generated when you create a webhook endpoint in Stripe → Webhooks.
# Required for the /api/billing/webhook handler to verify signatures.
STRIPE_WEBHOOK_SECRET=

# Optional — frontend Stripe publishable key (pk_test_… / pk_live_…).
# Only needed if you ever switch from hosted Checkout to embedded Elements.
STRIPE_PUBLISHABLE_KEY=


# ── TESTING ─────────────────────────────────────────────────────────────────
# Pointing this at a real Postgres unlocks the integration tests in
# backend/test that need to write to the DB. Without it, only the
# pure-function + auth-gate tests run. Use a Neon "test" branch in CI
# or a local docker postgres in dev.
TEST_DATABASE_URL=


# ── OBSERVABILITY (recommended — Audit 3.5) ─────────────────────────────────
# Sentry DSN for backend error tracking. Sign up at sentry.io, create
# a Node project, paste the DSN here. Empty = no error tracking.
SENTRY_DSN=

# Sentry traces sample rate — fraction of requests to send as
# performance traces. 0.1 = 10 %. Lower for high-traffic prod.
SENTRY_TRACES_SAMPLE_RATE=0.1


# ── BACKGROUND JOB QUEUE (Audit 4.3) ────────────────────────────────────────
# Redis URL for BullMQ. When set + bullmq is installed
# (`npm install bullmq ioredis`), services/queue.js switches from
# inline-execute to durable, retryable jobs. Empty = fallback mode
# (jobs run inline; no persistence). Add a Redis service in Railway
# (Upstash add-on or Railway's Redis plugin) to enable.
REDIS_URL=
