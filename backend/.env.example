# ── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/atp_db

# ── AUTH ─────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d
MAGIC_LINK_EXPIRES_IN=3600

# ── SERVER ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://attheparkworld.github.io

# ── EMAIL (SENDGRID) ─────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=no-reply@atthepark.world
EMAIL_FROM_NAME=At The Park

# ── GOOGLE OAUTH ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# ── APPLE OAUTH ──────────────────────────────────────────────
APPLE_CLIENT_ID=world.atthepark.app
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ── CLOUDINARY (profile photos / media) ──────────────────────
CLOUDINARY_CLOUD_NAME=atthepark
CLOUDINARY_API_KEY=xxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── SHOPIFY ──────────────────────────────────────────────────
SHOPIFY_STOREFRONT_TOKEN=31a1a5554b7f2fdaf2aa4dc44e13a127
SHOPIFY_DOMAIN=atp-store-7903.myshopify.com
SHOPIFY_WEBHOOK_SECRET=xxxxxxxxxxxx

# ── ADMIN ────────────────────────────────────────────────────
ADMIN_EMAIL=fredericmartins21@me.com
ADMIN_SETUP_KEY=change_this_before_deploying
